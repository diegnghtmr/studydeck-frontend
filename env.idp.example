# StudyDeck frontend — real OIDC login against the local Keycloak (idp overlay).
#
# Usage:
#   cp env.idp.example .env.local
#   pnpm dev            ->  http://localhost:5173  -> redirects to Keycloak -> log in as dev / dev
#
# Requires the backend IdP overlay running:
#   (studydeck-backend) docker compose -f compose.yaml -f compose.idp.yaml up -d
#
# For the lightweight dev-token flow instead, set VITE_DEV_ACCESS_TOKEN and leave the
# VITE_OIDC_* vars unset.

VITE_API_URL=http://localhost:8080

VITE_OIDC_AUTHORITY=http://localhost:8081/realms/studydeck
VITE_OIDC_CLIENT_ID=studydeck-spa
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
# Request only "openid" — the API scopes (study.*, ai.generate, mcp.invoke, …) are default
# client scopes in the realm and are included in the access token automatically, and the
# sub/email/name claims come from the client's protocol mappers. Requesting scopes that the
# realm doesn't define (e.g. profile/email as scopes) makes Keycloak return invalid_scope.
VITE_OIDC_SCOPE=openid
